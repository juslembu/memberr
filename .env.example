# Database
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgres://memberr:changeme@postgres:5432/memberr

# JWT Secrets — generate with: openssl rand -hex 64
JWT_SECRET=change_this_to_a_random_secret
REFRESH_TOKEN_SECRET=change_this_to_another_random_secret

# API
PORT=3000
NODE_ENV=development

# CORS — comma-separated origins
CORS_ORIGINS=https://memberr.cowjuice.xyz,http://localhost:8081,http://localhost:3000

# Optional: SMTP for invitation emails
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@memberr.app
