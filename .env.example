# Database
POSTGRES_PASSWORD=changeme
# Host is "localhost" because `pnpm --filter @memberr/api dev` runs on your machine, not in Docker
# (the Postgres container exposes 5432 to the host). The api Docker container ignores this line
# and builds its own DATABASE_URL pointed at the "postgres" service hostname — see docker-compose.yml.
DATABASE_URL=postgres://memberr:changeme@localhost:5432/memberr

# JWT Secrets — generate with: openssl rand -hex 64
JWT_SECRET=change_this_to_a_random_secret
REFRESH_TOKEN_SECRET=change_this_to_another_random_secret

# API
PORT=3000
NODE_ENV=development

# CORS — comma-separated origins
CORS_ORIGINS=https://memberr.cowjuice.xyz,http://localhost:8081,http://localhost:3000

# Optional: SMTP for invitation emails
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@memberr.app
