memberr.cowjuice.xyz {
    encode gzip

    # Serve Expo web build (if present)
    handle /static/* {
        root * /srv/web
        file_server
    }

    # API
    handle /api/* {
        reverse_proxy api:3000
    }

    handle /health {
        reverse_proxy api:3000
    }

    # SPA fallback — try path, path.html, then index.html
    handle {
        root * /srv/web
        try_files {path} {path}.html /index.html
        file_server
    }
}
