{
  "name": "memberr",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "db:migrate": "pnpm --filter @memberr/api db:migrate",
    "db:generate": "pnpm --filter @memberr/api db:generate",
    "deploy:web": "pnpm --filter @memberr/mobile build:web && docker compose -f docker-compose.yml -f docker-compose.prod.yml up -d --force-recreate caddy"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@10.0.0"
}
